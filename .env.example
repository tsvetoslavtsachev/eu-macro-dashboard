# Copy this file to `.env` if you need to override default endpoints (rare).
# .env is in .gitignore — it will never be committed.
#
# ECB SDW и Eurostat REST не изискват API key — endpoint-ите са публични.
# Този файл е placeholder за staging/proxy override-и.

# ECB_API_BASE=https://data-api.ecb.europa.eu/service
# EUROSTAT_API_BASE=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0
